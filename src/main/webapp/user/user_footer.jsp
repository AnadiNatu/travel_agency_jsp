<%--<%@page contentType="text/html" pageEncoding="UTF-8"%>--%>

<!-- Bootstrap Icons -->
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .glass-footer {
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-top: 1px solid rgba(255, 255, 255, 0.25);
        box-shadow: 0 -5px 20px rgba(0,0,0,0.08);
        padding: 40px 0;
        margin-top: 60px;
        text-align: center;
    }

    .footer-logo {
        font-size: 26px;
        font-weight: 700;
        color: #e1a400;
        letter-spacing: 1px;
    }

    .footer-desc {
        max-width: 480px;
        margin: 15px auto;
        font-size: 15px;
        color: #333;
        line-height: 1.5;
    }

    .footer-social a {
        font-size: 22px;
        margin: 0 12px;
        color: #555;
        transition: 0.3s ease;
        text-decoration: none;
    }

    .footer-social a:hover {
        color: #e1a400;
        transform: translateY(-3px);
    }

    .footer-copy {
        margin-top: 20px;
        font-size: 14px;
        color: #444;
    }
</style>

<footer class="glass-footer">
    <div class="container">

        <div class="footer-logo">ExploreEase</div>

        <p class="footer-desc">
            Your trusted travel partner ? discover tours, explore destinations, book trips,
            and enjoy seamless travel experiences with comfort and convenience.
        </p>

        <div class="footer-social">
            <a href="#"><i class="bi bi-facebook"></i></a>
            <a href="#"><i class="bi bi-instagram"></i></a>
            <a href="#"><i class="bi bi-twitter"></i></a>
        </div>

        <p class="footer-copy">© 2025 Explore Ease. All Rights Reserved.</p>

    </div>
</footer>
